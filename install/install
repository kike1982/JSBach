#!/bin/bash
set -e

####################################
### comprobar root
####################################
if [ "$EUID" -ne 0 ]; then
  echo "Este script debe ejecutarse como root"
  exit 1
fi
source "$(cd "$(dirname "$0")/.." && pwd)/conf/variables.conf"
#source /usr/local/JSBach/conf/variables.conf

####################################
### Funciones del primer script
####################################

fnc_copia_fitxers() {
    ORIGEN="../"
    DESTI="/usr/local"
    NOM_CARPETA=JSBach
    DESTI_FINAL="$DESTI/$NOM_CARPETA"

    echo "📁 Copiando ficheros a $DESTI_FINAL..."

    # Copiar carpeta JSBach
    cp -r "$ORIGEN" "$DESTI_FINAL"

    # Ajustar propietario root:root
    chown -R root:root "$DESTI_FINAL"

    echo "🔐 Ajustando permisos de $DESTI_FINAL"
    chmod -R 755 "$DESTI_FINAL"
}

fnc_instala_aplicacions() {
    echo "⚙️ Instalando aplicaciones necesarias..."
    apt update

    for paquete in net-tools iw apache2 curl expect hostapd dnsmasq; do
        echo "⚙️ Instalando $paquete"
        apt install -y "$paquete"
    done

    echo "⚙️ Activando módulo CGI de Apache"
    a2enmod cgi

    echo "📝 Creando configuración Apache para JSBach CGI"
    cat > /etc/apache2/conf-available/jsbach-cgi.conf <<-'EOF'
    ScriptAlias /cgi-bin/ /usr/local/JSBach/cgi-bin/

    <Directory "/usr/local/JSBach/cgi-bin">
        AllowOverride None
        Options +ExecCGI -MultiViews +SymLinksIfOwnerMatch
        Require all granted
        AddHandler cgi-script .cgi
    </Directory>
EOF

    echo "✅ Activando configuración Apache"
    a2enconf jsbach-cgi
    systemctl restart apache2
}

fnc_detectar_wifi() {
    echo "🔍 Detectant interfície WiFi..."

    # Buscar interfaces wireless a /sys/class/net
    WIFI_IFACES=()
    for iface in /sys/class/net/*/; do
        IFACE_NAME=$(basename "$iface")
        if [ -d "$iface/wireless" ]; then
            WIFI_IFACES+=("$IFACE_NAME")
        fi
    done

    if [ ${#WIFI_IFACES[@]} -eq 0 ]; then
        echo "⚠️  No s'ha detectat cap interfície WiFi. Edita manualment conf/wifi.conf (camp WIFI_IF)."
        return
    fi

    if [ ${#WIFI_IFACES[@]} -eq 1 ]; then
        WIFI_IFACE="${WIFI_IFACES[0]}"
        echo "✅ Interfície WiFi detectada: $WIFI_IFACE"
    else
        echo "S'han detectat múltiples interfícies WiFi:"
        for i in "${!WIFI_IFACES[@]}"; do
            echo "  $((i+1))) ${WIFI_IFACES[$i]}"
        done
        read -rp "Escull el número de la interfície a usar per l'AP WiFi: " OPCIO
        WIFI_IFACE="${WIFI_IFACES[$((OPCIO-1))]}"
        echo "✅ Interfície seleccionada: $WIFI_IFACE"
    fi

    # Escriure WIFI_IF a wifi.conf
    WIFI_CONF_FILE="/usr/local/JSBach/conf/wifi.conf"
    if [ -f "$WIFI_CONF_FILE" ]; then
        sed -i "s/^WIFI_IF=.*/WIFI_IF=$WIFI_IFACE/" "$WIFI_CONF_FILE"
        echo "📝 wifi.conf actualitzat amb WIFI_IF=$WIFI_IFACE"
    else
        echo "⚠️  No s'ha trobat $WIFI_CONF_FILE"
    fi
}

####################################
### desactivar NetworkManager
####################################
echo "Desactivando NetworkManager"
systemctl stop NetworkManager || true
systemctl disable NetworkManager || true
echo

####################################
### Copiar ficheros e instalar apps
####################################
fnc_copia_fitxers
fnc_instala_aplicacions

####################################
### configurar Apache CGI adicional (opcional)
####################################
# Aquí mantenemos tu configuración previa
APACHE_CGI_CONF="/etc/apache2/conf-available/serve-cgi-bin.conf"
cp "$APACHE_CGI_CONF" "${APACHE_CGI_CONF}.bak"

cat > "$APACHE_CGI_CONF" << 'EOF'
<IfModule mod_alias.c>
	<IfModule mod_cgi.c>
		Define ENABLE_USR_LIB_CGI_BIN
	</IfModule>

	<IfModule mod_cgid.c>
		Define ENABLE_USR_LIB_CGI_BIN
	</IfModule>

	<IfDefine ENABLE_USR_LIB_CGI_BIN>
		ScriptAlias /cgi-bin/ /usr/local/JSBach/cgi-bin/
		<Directory "/usr/local/JSBach/cgi-bin">
			AllowOverride None
			Options +ExecCGI -MultiViews +SymLinksIfOwnerMatch
			Require all granted
		</Directory>
	</IfDefine>
</IfModule>
EOF

a2enconf serve-cgi-bin
systemctl reload apache2

####################################
### crear servicio systemd
####################################
SERVICE_FILE="/etc/systemd/system/srv_cli.service"

echo "Creando servicio systemd srv_cli"

cat > "$SERVICE_FILE" << 'EOF'
[Unit]
Description=Servicio JSBach srv_cli
After=network-pre.target

[Service]
Type=simple
ExecStart=/usr/local/JSBach/system/srv_cli
WorkingDirectory=/usr/local/JSBach/system/
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
EOF

chmod +x "$SERVICE_FILE"

####################################
### activar y arrancar servicio
####################################
systemctl daemon-reload
systemctl enable srv_cli.service
systemctl start srv_cli.service

echo
echo "Estado del servicio:"
systemctl status srv_cli.service --no-pager
